#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
LOGO_FILE="$ROOT_DIR/logo.txt"
SIG_FILE="$ROOT_DIR/sig.txt"

DRY_RUN=0
BACKUP=0

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    --backup) BACKUP=1 ;;
    *)
      printf 'Unknown option: %s\n' "$arg" >&2
      printf 'Usage: %s [--dry-run] [--backup]\n' "$(basename "$0")" >&2
      exit 1
      ;;
  esac
done

if [[ ! -f "$LOGO_FILE" || ! -f "$SIG_FILE" ]]; then
  printf 'Missing logo.txt or sig.txt in %s\n' "$ROOT_DIR" >&2
  exit 1
fi

mapfile -t LOGO_LINES < "$LOGO_FILE"
mapfile -t SIG_LINES < "$SIG_FILE"

comment_style_for_file() {
  local file="$1"
  local base ext
  base="$(basename "$file")"
  ext="${base##*.}"

  case "$ext" in
    css) echo "css" ;;
    lua) echo "lua" ;;
    conf|ini|toml|yaml|yml) echo "hash" ;;
    theme)
      case "$base" in
        btop.theme) echo "hash" ;;
        *) echo "none" ;;
      esac
      ;;
    *) echo "none" ;;
  esac
}

build_commented_lines() {
  local style="$1"
  local source_name="$2"
  local out_name="$3"
  local -n src="$source_name"
  local -n out="$out_name"
  local line

  out=()
  case "$style" in
    hash)
      for line in "${src[@]}"; do
        if [[ -n "$line" ]]; then
          out+=("# $line")
        else
          out+=("#")
        fi
      done
      ;;
    lua)
      for line in "${src[@]}"; do
        if [[ -n "$line" ]]; then
          out+=("-- $line")
        else
          out+=("--")
        fi
      done
      ;;
    css)
      for line in "${src[@]}"; do
        out+=("/* $line */")
      done
      ;;
    *)
      printf 'Unsupported style: %s\n' "$style" >&2
      exit 1
      ;;
  esac
}

remove_marker_lines() {
  local input_name="$1"
  local out_name="$2"
  local -n in="$input_name"
  local -n out="$out_name"
  local line

  out=()
  for line in "${in[@]}"; do
    if [[ "$line" == *OMARCHY_AUTO_LOGO_START* || "$line" == *OMARCHY_AUTO_LOGO_END* || "$line" == *OMARCHY_AUTO_SIG_START* || "$line" == *OMARCHY_AUTO_SIG_END* ]]; then
      continue
    fi
    out+=("$line")
  done
}

trim_outer_blank_lines() {
  local arr_name="$1"
  local -n arr="$arr_name"
  local start=0
  local end=$(( ${#arr[@]} - 1 ))

  while (( start <= end )) && [[ "${arr[$start]}" =~ ^[[:space:]]*$ ]]; do
    start=$((start + 1))
  done
  while (( end >= start )) && [[ "${arr[$end]}" =~ ^[[:space:]]*$ ]]; do
    end=$((end - 1))
  done

  if (( start > end )); then
    arr=()
    return
  fi

  arr=( "${arr[@]:$start:$((end - start + 1))}" )
}

strip_leading_block() {
  local arr_name="$1"
  local block_name="$2"
  local -n arr="$arr_name"
  local -n block="$block_name"
  local i

  if (( ${#arr[@]} < ${#block[@]} )); then
    return
  fi
  for (( i=0; i<${#block[@]}; i++ )); do
    if [[ "${arr[$i]}" != "${block[$i]}" ]]; then
      return
    fi
  done

  arr=( "${arr[@]:${#block[@]}}" )
  trim_outer_blank_lines "$arr_name"
}

strip_trailing_block() {
  local arr_name="$1"
  local block_name="$2"
  local -n arr="$arr_name"
  local -n block="$block_name"
  local offset i

  if (( ${#arr[@]} < ${#block[@]} )); then
    return
  fi

  offset=$(( ${#arr[@]} - ${#block[@]} ))
  for (( i=0; i<${#block[@]}; i++ )); do
    if [[ "${arr[$((offset + i))]}" != "${block[$i]}" ]]; then
      return
    fi
  done

  arr=( "${arr[@]:0:$offset}" )
  trim_outer_blank_lines "$arr_name"
}

process_file() {
  local file="$1"
  local style
  style="$(comment_style_for_file "$file")"

  if [[ "$style" == "none" ]]; then
    return 0
  fi

  local -a existing_lines no_markers core_lines logo_block sig_block new_lines
  local new_content tmp_file

  mapfile -t existing_lines < "$file"

  remove_marker_lines existing_lines no_markers
  core_lines=( "${no_markers[@]}" )
  trim_outer_blank_lines core_lines

  build_commented_lines "$style" LOGO_LINES logo_block
  build_commented_lines "$style" SIG_LINES sig_block

  strip_leading_block core_lines logo_block
  strip_trailing_block core_lines sig_block

  new_lines=( "${logo_block[@]}" "" )
  if (( ${#core_lines[@]} > 0 )); then
    new_lines+=( "${core_lines[@]}" "" )
  fi
  new_lines+=( "${sig_block[@]}" )

  new_content="$(printf '%s\n' "${new_lines[@]}")"

  if [[ "$DRY_RUN" -eq 1 ]]; then
    if ! diff -q <(printf '%s' "$new_content") "$file" >/dev/null 2>&1; then
      printf 'Would update: %s\n' "${file#$ROOT_DIR/}"
    fi
    return 0
  fi

  if [[ "$BACKUP" -eq 1 ]]; then
    cp "$file" "$file.bak"
  fi

  tmp_file="$(mktemp)"
  printf '%s' "$new_content" > "$tmp_file"
  mv "$tmp_file" "$file"
  printf 'Updated: %s\n' "${file#$ROOT_DIR/}"
}

cd "$ROOT_DIR"

while IFS= read -r -d '' file; do
  process_file "$file"
done < <(find "$ROOT_DIR" -maxdepth 1 -type f -print0)

if [[ "$DRY_RUN" -eq 1 ]]; then
  printf 'Dry-run complete.\n'
fi
